# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# Node
node_modules/
npm-debug.log
yarn-debug.log
yarn-error.log

# Build outputs
frontend/dist/
backend/dist/

# OS junk
.DS_Store
Thumbs.db

# Local archives
backend/_archive_2d/

# ====================================================================
# Generated / cached assets (regenerated by the pipeline on demand)
# ====================================================================

# Pre-rendered 3D avatar MP4s (~130KB each × thousands)
data/avatar_videos_3d/*.mp4
data/avatar_videos_3d/*.bones.json
data/avatar_videos_3d/stitched/*.mp4

# Per-token stitched/cached output
data/avatar_videos/*.mp4
data/avatar_videos/stitched/
data/stitched_videos/

# Skeleton videos (regenerated from mocap JSON via skeleton_renderer.py)
data/skeleton_videos/*.mp4

# Per-token retargeted/merged GLBs (regenerated by retarget_digihuman.py)
data/avatars/arab-man/_*_anim.glb
data/avatars/arab-man/_*_digiv2_anim.glb
data/avatars/arab-man/_*_layered.glb
data/avatars/arab-man/arab_sheik_*.glb

# Source signing videos downloaded from Vimeo (large, re-fetchable from manifest)
data/motion_db/*.mp4
data/motion_db/*.avi

# MediaPipe extraction caches (regenerated by extract_v2.py / build_pose_db.py)
data/processed/mocap_holistic_v2/*.json
data/processed/mocap_holistic/*.json
data/processed/mocap_2d/*.json
# Keep data/processed/mocap/*.json (smaller, used by skeleton renderer)

# OpenAI translation cache (regenerated on demand)
data/processed/en2ar_cache.json

# Logs / state
*.log
state/
.openclaw/

# Hugging Face / models
models/
*.task
*.pkl
*.bin
*.onnx
*.safetensors

# Misc debugging output
*.tmp.avi
_debug_*.jpg
_debug_*.png

# Session-only debug scratch
tmp_debug/

# Runtime-generated stitched video metadata
data/avatar_videos_3d/stitched/*.tokens.json
data/stitched_videos/*.tokens.json

# Padded landmark renders + per-sign side-by-side videos (regeneratable)
data/avatar_videos_3d/_landmarks_*.mp4
data/avatar_videos_3d/*_sidebyside.mp4

# Headless render frame scratch dirs
scripts/animate/.frames-*/
*_backup.glb

# Regeneratable mocap JSON cache (12MB+, produced by scrape.py)
data/processed/mocap/
logs/
